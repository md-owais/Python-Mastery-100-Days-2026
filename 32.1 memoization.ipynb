   "source": [
    "import time\n",
    "def memo(m, d):\n",
    "    if m in d:\n",
    "        return d[m]\n",
    "    else:\n",
    "        d[m] = memo(m - 1,d) + memo(m - 2, d)\n",
    "        return d[m]\n",
    "\n",
    "start = time.time()\n",
    "d = {0:1, 1:1}\n",
    "print(memo(48,d))\n",
    "print(time.time() - start)\n",
    "print(d)"
   ]
